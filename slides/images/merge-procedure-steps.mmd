        I0["L = [2, 4, 5, 7, INF]\nR = [1, 2, 3, 6, INF]\nA[9..16] = [_, _, _, _, _, _, _, _]\ni = 1, j = 1"]:::card
    end

    subgraph Trace1["Steps 1-4"]
