        S1["k = 9\n2 vs 1 -> take R[j]\nA = [1, _, _, _, _, _, _, _]\nj moves to 2"]:::merge
        S2["k = 10\n2 vs 2 -> take L[i] (<=)\nA = [1, 2, _, _, _, _, _, _]\ni moves to 2"]:::merge
        S3["k = 11\n4 vs 2 -> take R[j]\nA = [1, 2, 2, _, _, _, _, _]\nj moves to 3"]:::merge
        S4["k = 12\n4 vs 3 -> take R[j]\nA = [1, 2, 2, 3, _, _, _, _]\nj moves to 4"]:::merge
    end

    subgraph Trace2["Steps 5-8"]
        direction TD
        S5["k = 13\n4 vs 6 -> take L[i]\nA = [1, 2, 2, 3, 4, _, _, _]\ni moves to 3"]:::merge
