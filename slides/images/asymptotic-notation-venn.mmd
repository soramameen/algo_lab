%% ID: C3-03
%% Asymptotic notation inclusion relationships
%% Theta ⊂ O, Theta ⊂ Omega, o ⊂ O, omega ⊂ Omega
%% Concept diagram using nested subgraphs (Mermaid cannot render true Venn diagrams)
flowchart TD
    subgraph Oset["O(g) — asymptotic upper bound"]
        direction TB
        subgraph ThetaInO["Θ(g) — tight bound"]
            ThetaNode["f(n) ∈ Θ(g)"]:::theta
        end
        subgraph oInO["o(g) — strictly smaller"]
            oNode["f(n) ∈ o(g)"]:::littleo
        end
        Orest["(other f = O(g) only)"]:::remainder
    end

    subgraph Omegaset["Ω(g) — asymptotic lower bound"]
        direction TB
        subgraph ThetaInOmega["Θ(g) — tight bound"]
            ThetaNode2["f(n) ∈ Θ(g)"]:::theta
        end
        subgraph omegaInOmega["ω(g) — strictly larger"]
            omegaNode["f(n) ∈ ω(g)"]:::littleomega
        end
        Omegarest["(other f = Ω(g) only)"]:::remainder
    end

    ThetaNode -.- ThetaNode2

    classDef theta fill:#f3e5f5,stroke:#9c27b0,stroke-width:1.5px,color:#24292f,rx:10,ry:10
    classDef littleo fill:#f3e5f5,stroke:#ce93d8,stroke-width:1.5px,color:#24292f,rx:10,ry:10
    classDef littleomega fill:#fff3e0,stroke:#ffb74d,stroke-width:1.5px,color:#24292f,rx:10,ry:10
    classDef remainder fill:#f5f5f5,stroke:#bdbdbd,stroke-width:1px,color:#757575,rx:10,ry:10
